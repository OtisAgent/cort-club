<style>
.cp-feature__icon {
  font-size: 28px;
  font-weight: 900;
  color: var(--cp-black);
  margin-bottom: 20px;
  line-height: 1;
}
</style>

<section class="cp-features">
  <div class="cp-features__inner">
    <p class="cp-section-eyebrow">What you can do</p>
    <h2 class="cp-section-heading">Every format. One platform.</h2>
    <div class="cp-features__grid">
      <div class="cp-feature">
        <div class="cp-feature__icon">↺</div>
        <h3 class="cp-feature__title">Americano Generator</h3>
        <p class="cp-feature__body">Set your players, courts and rounds — CØRT Play builds the schedule in seconds. Rotating pairs, auto-balanced draws, live score entry, instant leaderboard.</p>
        <span class="cp-feature__tag">V1 Launch</span>
      </div>
      <div class="cp-feature">
        <div class="cp-feature__icon">⟫</div>
        <h3 class="cp-feature__title">Mexicano Format</h3>
        <p class="cp-feature__body">Dynamic matchmaking based on live standings. After every round, top plays top, bottom plays bottom. The closest matches happen automatically — no manual seeding.</p>
        <span class="cp-feature__tag">V1 Launch</span>
      </div>
      <div class="cp-feature">
        <div class="cp-feature__icon">◆</div>
        <h3 class="cp-feature__title">League Management</h3>
        <p class="cp-feature__body">Run a full seasonal league: divisions, promotion/relegation, weekly fixtures, results tracking, and a final standings table your players can check any time.</p>
        <span class="cp-feature__tag">Coming Soon</span>
      </div>
      <div class="cp-feature">
        <div class="cp-feature__icon">★</div>
        <h3 class="cp-feature__title">CØRT Rating System</h3>
        <p class="cp-feature__body">A persistent skill rating that follows players across every event. Win strong opponents, gain more. Lose to weaker players, lose less. The system rewards real performance.</p>
        <span class="cp-feature__tag">V1 Launch</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CØRT Play Features",
  "settings": []
}
{% endschema %}
