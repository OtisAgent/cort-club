<section class="cp-rating">
  <div class="cp-rating__inner">
    <div>
      <p class="cp-rating__label">The CØRT Rating</p>
      <h2 class="cp-rating__heading">A number that actually means something.</h2>
      <p class="cp-rating__body">Most club ladders are honesty-based and quickly go stale. The CØRT Rating is calculated automatically from every result across every event — so it reflects how you actually play right now, not how you played six months ago.</p>
    </div>
    <div class="cp-rating__tiers">
      <div class="cp-rating__tier">
        <span class="cp-rating__tier-badge" style="color:#888;">Beginner</span>
        <div class="cp-rating__tier-bar-wrap"><div class="cp-rating__tier-bar" style="width:20%;"></div></div>
        <span class="cp-rating__tier-range">1.0 – 2.0</span>
      </div>
      <div class="cp-rating__tier">
        <span class="cp-rating__tier-badge" style="color:#666;">Improver</span>
        <div class="cp-rating__tier-bar-wrap"><div class="cp-rating__tier-bar" style="width:40%;"></div></div>
        <span class="cp-rating__tier-range">2.0 – 3.5</span>
      </div>
      <div class="cp-rating__tier">
        <span class="cp-rating__tier-badge" style="color:#444;">Club</span>
        <div class="cp-rating__tier-bar-wrap"><div class="cp-rating__tier-bar" style="width:60%;"></div></div>
        <span class="cp-rating__tier-range">3.5 – 5.0</span>
      </div>
      <div class="cp-rating__tier">
        <span class="cp-rating__tier-badge" style="color:#222;">Advanced</span>
        <div class="cp-rating__tier-bar-wrap"><div class="cp-rating__tier-bar" style="width:80%;"></div></div>
        <span class="cp-rating__tier-range">5.0 – 7.0</span>
      </div>
      <div class="cp-rating__tier">
        <span class="cp-rating__tier-badge" style="color:#000;">Elite</span>
        <div class="cp-rating__tier-bar-wrap"><div class="cp-rating__tier-bar" style="width:100%;"></div></div>
        <span class="cp-rating__tier-range">7.0+</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CØRT Play Rating",
  "settings": []
}
{% endschema %}
