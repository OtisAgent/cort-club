{{ 'cortv2.css' | asset_url | stylesheet_tag }}

<div class="cortv2">

  <section class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow reveal" style="--d:.06s">The home of grassroots padel</p>
      <div class="hero-wordmark reveal" style="--d:.12s">cørt<span class="hero-wordmark-dot"></span></div>
      <p class="hero-headline reveal" style="--d:.18s">Where padel <em>happens.</em></p>
      <div class="events-board">
        <div class="events-board-head reveal" style="--d:.16s">
          <span class="events-board-dot"></span>
          <span class="events-board-title">What's on</span>
        </div>
        <div class="events-grid">
          <div class="event-card reveal">
            <span class="event-tag">Free to enter</span>
            <h3 class="event-name">Americano Night</h3>
            <p class="event-format">Americano · Social round-robin, all levels</p>
            <div class="event-meta"><span>Sheffield</span><span>Thursday · 7:00pm</span></div>
          </div>
          <div class="event-card reveal">
            <span class="event-tag">Open</span>
            <h3 class="event-name">King of the Court</h3>
            <p class="event-format">Open session · Winners stay on</p>
            <div class="event-meta"><span>Sheffield</span><span>Saturday · 10:00am</span></div>
          </div>
          <div class="event-card reveal">
            <span class="event-tag">Open</span>
            <h3 class="event-name">CØRT League Matchday</h3>
            <p class="event-format">League · Round one, teams of two</p>
            <div class="event-meta"><span>Venue TBC</span><span>Sunday · 2:00pm</span></div>
          </div>
        </div>
      </div>
      <p class="hero-soon reveal" style="--d:.46s">First events landing soon — join the list to hear first.</p>
      <div class="hero-actions reveal" style="--d:.52s">
        <a href="#cort-join" class="btn btn-yellow btn-dot">Join the list</a>
      </div>
    </div>
  </section>

  <section class="connector" id="cort-connector">
    <p class="section-eyebrow reveal">How CØRT connects the game</p>
    <h2 class="section-title reveal" style="--d:.06s">One game.<br>One place.</h2>
    <div class="connector-flow">
      <div class="connector-node reveal">
        <div class="connector-node-icon"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5.5" width="18" height="13" rx="1.6"/><path d="M12 5.5v13"/><path d="M3 12h4.5M16.5 12h4.5"/></svg></div>
        <div class="connector-node-name">Padel clubs</div>
        <div class="connector-node-sub">where it's played</div>
      </div>
      <span class="connector-arrow reveal" aria-hidden="true"></span>
      <div class="connector-node reveal">
        <div class="connector-node-icon"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.5" y="5" width="17" height="15" rx="2"/><path d="M3.5 9.6h17M8.2 3v3.6M15.8 3v3.6"/><circle cx="8.4" cy="13.6" r="1" fill="currentColor" stroke="none"/><circle cx="12" cy="13.6" r="1" fill="currentColor" stroke="none"/><circle cx="15.6" cy="13.6" r="1" fill="currentColor" stroke="none"/></svg></div>
        <div class="connector-node-name">Events</div>
        <div class="connector-node-sub">where it happens</div>
      </div>
      <span class="connector-arrow reveal" aria-hidden="true"></span>
      <div class="connector-node connector-node-hub reveal">
        <div class="connector-hub-brand">cørt<span></span></div>
        <div class="connector-hub-tag">The connector</div>
      </div>
      <span class="connector-arrow reveal" aria-hidden="true"></span>
      <div class="connector-node reveal">
        <div class="connector-node-icon"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2.8" y="7" width="12.6" height="10" rx="2"/><path d="M15.4 10.6l5.4-2.8v8.4l-5.4-2.8"/></svg></div>
        <div class="connector-node-name">Broadcasting</div>
        <div class="connector-node-sub">where it's watched</div>
      </div>
      <span class="connector-arrow reveal" aria-hidden="true"></span>
      <div class="connector-node reveal">
        <div class="connector-node-icon"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.1 13.9a4.2 4.2 0 0 0 5.9 0l3.2-3.2a4.2 4.2 0 0 0-5.9-5.9l-1.7 1.7"/><path d="M13.9 10.1a4.2 4.2 0 0 0-5.9 0l-3.2 3.2a4.2 4.2 0 0 0 5.9 5.9l1.7-1.7"/></svg></div>
        <div class="connector-node-name">Sponsorship</div>
        <div class="connector-node-sub">where brands plug in</div>
      </div>
      <span class="connector-arrow reveal" aria-hidden="true"></span>
      <div class="connector-node reveal">
        <div class="connector-node-icon"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5.9 8.2h12.2l-.95 11.1a2 2 0 0 1-2 1.9H8.85a2 2 0 0 1-2-1.9z"/><path d="M8.8 10.6V6.8a3.2 3.2 0 0 1 6.4 0v3.8"/></svg></div>
        <div class="connector-node-name">Shop</div>
        <div class="connector-node-sub">where the game gears up</div>
      </div>
    </div>
  </section>

  <section class="pillars" id="cort-club">
    <p class="section-eyebrow reveal">The CØRT Ecosystem</p>
    <h2 class="section-title reveal" style="--d:.06s">Everything padel.<br>One club.</h2>
    <div class="pillars-grid">
      <a href="#cort-join" class="pillar-card reveal">
        <div class="pillar-icon"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="8.4" r="3.3"/><path d="M3.4 20.2c0-3.1 2.5-5.3 5.6-5.3s5.6 2.2 5.6 5.3"/><path d="M15.6 5.5a3.3 3.3 0 0 1 0 5.8"/><path d="M17.8 15.4c1.8.7 2.9 2.1 2.9 4"/></svg></div>
        <p class="pillar-num"><span class="pillar-num-dot"></span>01 — CØRT Club</p>
        <h3 class="pillar-title">Community</h3>
        <p class="pillar-desc">Events, leagues and a connected network of padel players across the UK — from first-timers to competitors.</p>
        <span class="pillar-link">Join →</span>
      </a>
      <a href="/pages/cort-tv" class="pillar-card reveal">
        <div class="pillar-icon"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2.8" y="7" width="12.6" height="10" rx="2"/><path d="M15.4 10.6l5.4-2.8v8.4l-5.4-2.8"/></svg></div>
        <p class="pillar-num"><span class="pillar-num-dot"></span>02 — CØRT TV</p>
        <h3 class="pillar-title">Watch</h3>
        <p class="pillar-desc">Live nights, highlights and match content — plus sponsorship and media partnerships for brands entering padel.</p>
        <span class="pillar-link">Watch →</span>
      </a>
      <a href="https://play.cortclub.co.uk" class="pillar-card reveal">
        <div class="pillar-icon"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2.7c3.7 0 6.4 2.7 6.4 6.1 0 3.2-2.3 5.8-4.9 6.4l-.3 4.4c-.1.9-.6 1.7-1.2 1.7s-1.1-.8-1.2-1.7l-.3-4.4c-2.6-.6-4.9-3.2-4.9-6.4C5.6 5.4 8.3 2.7 12 2.7Z"/><circle cx="9.8" cy="7.6" r="0.9" fill="currentColor" stroke="none"/><circle cx="14.2" cy="7.6" r="0.9" fill="currentColor" stroke="none"/><circle cx="12" cy="10.4" r="0.9" fill="currentColor" stroke="none"/></svg></div>
        <p class="pillar-num"><span class="pillar-num-dot"></span>03 — CØRT Play</p>
        <h3 class="pillar-title">Run sessions</h3>
        <p class="pillar-desc">Americano, Mexicano, King of the Court — set up and run your sessions in minutes, zero admin.</p>
        <span class="pillar-link">play.cortclub.co.uk →</span>
      </a>
      <a href="#cort-shop" class="pillar-card reveal">
        <div class="pillar-icon"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5.9 8.2h12.2l-.95 11.1a2 2 0 0 1-2 1.9H8.85a2 2 0 0 1-2-1.9z"/><path d="M8.8 10.6V6.8a3.2 3.2 0 0 1 6.4 0v3.8"/></svg></div>
        <p class="pillar-num"><span class="pillar-num-dot"></span>04 — CØRT Shop</p>
        <h3 class="pillar-title">Shop</h3>
        <p class="pillar-desc">CØRT merch, curated padel gear and bundle deals built for the court — buy more, save more.</p>
        <span class="pillar-link">Shop →</span>
      </a>
    </div>
  </section>

  <section class="product-section" id="cort-shop">
    <div class="product-inner">
      <div class="reveal">
        <p class="product-eyebrow">CØRT Shop — Live Now</p>
        <h2 class="product-title">CØRT<br>Grip Socks</h2>
        <p class="product-desc">Our first in-house product. Non-slip grip technology designed for lateral movement on the padel court. Available in black and white.</p>
        <div class="chips">
          <span class="chip">Non-slip grip</span>
          <span class="chip">Black &amp; White</span>
          <span class="chip">Medium</span>
          <span class="chip">Large</span>
          <span class="live-chip"><span class="live-dot"></span>Available now</span>
        </div>
        <div class="product-price">£9.99</div>
        <p class="bundle-note"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="8.4"/><path d="M12 8.6v6.8M8.6 12h6.8"/></svg>Buy more, save more — bundle deals at checkout</p>
        <a href="/collections/grip-socks" class="btn btn-yellow btn-dot">Shop Grip Socks</a>
      </div>
      <div class="product-visual reveal" style="--d:.12s">
        <div class="product-visual-mark"><svg viewBox="0 0 100 100"><circle cx="50" cy="50" r="40" fill="none" stroke="#fff" stroke-width="8"/><line x1="18" y1="82" x2="82" y2="18" stroke="#fff" stroke-width="9" stroke-linecap="butt"/></svg></div>
        <span class="product-add-label">Photos coming soon</span>
      </div>
    </div>
  </section>

  <section class="member-section" id="cort-membership">
    <div class="member-inner">
      <p class="member-eyebrow reveal">CØRT Membership</p>
      <span class="soon-pill reveal" style="--d:.05s">Coming soon</span>
      <h2 class="member-title reveal" style="--d:.1s">Membership —<br>coming soon.</h2>
      <p class="member-desc reveal" style="--d:.15s">One card across the whole CØRT ecosystem. We're building the benefits with the community — nothing locked in yet, everything announced soon.</p>
      <div class="member-card-wrap reveal" style="--d:.2s">
        <div class="member-card">
          <div class="member-card-top">
            <div class="member-card-brand">cørt<span></span></div>
            <div class="member-card-chip">Member</div>
          </div>
          <div>
            <div class="member-card-name">A. Player</div>
            <div class="member-card-meta">
              <span class="member-card-num">Nº 0001</span>
              <span class="member-card-since">Est. 2026</span>
            </div>
          </div>
        </div>
      </div>
      <div class="tier-grid">
        <div class="tier-card reveal">
          <p class="tier-name">Courtside</p>
          <div class="tier-price">Free</div>
          <div class="tier-body"><p class="tier-body-label">What's inside — announced soon</p><p>Benefits are being built with the community and announced before launch.</p></div>
        </div>
        <div class="tier-card reveal">
          <p class="tier-name">Club</p>
          <div class="tier-price">£9<span>/mo</span></div>
          <div class="tier-body"><p class="tier-body-label">What's inside — announced soon</p><p>Benefits are being built with the community and announced before launch.</p></div>
        </div>
        <div class="tier-card reveal">
          <p class="tier-name">Pro</p>
          <div class="tier-price">£19<span>/mo</span></div>
          <div class="tier-body"><p class="tier-body-label">What's inside — announced soon</p><p>Benefits are being built with the community and announced before launch.</p></div>
        </div>
      </div>
      <a href="#cort-join" class="btn btn-yellow btn-dot reveal">Join the waitlist to hear first</a>
      <p class="member-note reveal" style="--d:.08s">Founding pricing — may change before launch.</p>
    </div>
  </section>

  <section class="partner-strip" id="cort-partner">
    <div class="partner-strip-inner">
      <div class="reveal">
        <p class="section-eyebrow" style="text-align:left">CØRT Partners</p>
        <h2 class="partner-strip-title">Your brand,<br>our court.</h2>
        <p class="partner-strip-desc">Sell your gear to the padel community through the CØRT store, or get your repair service listed where players already are. Every partner is vetted.</p>
      </div>
      <div class="reveal" style="--d:.12s">
        <ul class="partner-strip-tracks">
          <li><span><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5.9 8.2h12.2l-.95 11.1a2 2 0 0 1-2 1.9H8.85a2 2 0 0 1-2-1.9z"/><path d="M8.8 10.6V6.8a3.2 3.2 0 0 1 6.4 0v3.8"/></svg></span><span><strong>Brands</strong> — you hold stock, we list, market and sell it.</span></li>
          <li><span><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2.7c3.7 0 6.4 2.7 6.4 6.1 0 3.2-2.3 5.8-4.9 6.4l-.3 4.4c-.1.9-.6 1.7-1.2 1.7s-1.1-.8-1.2-1.7l-.3-4.4c-2.6-.6-4.9-3.2-4.9-6.4C5.6 5.4 8.3 2.7 12 2.7Z"/><circle cx="9.8" cy="7.6" r="0.9" fill="currentColor" stroke="none"/><circle cx="14.2" cy="7.6" r="0.9" fill="currentColor" stroke="none"/><circle cx="12" cy="10.4" r="0.9" fill="currentColor" stroke="none"/></svg></span><span><strong>Repair services</strong> — regrip and repair bookings from the community.</span></li>
        </ul>
        <a href="/pages/cort-partners" class="btn btn-black btn-dot">Apply to partner</a>
      </div>
    </div>
  </section>

  <section class="capture" id="cort-join">
    <div class="capture-inner reveal">
      <h2>Join the CØRT Community<span class="cap-dot"></span></h2>
      <p>Events, league news, member drops and more. Be first in.</p>
      <form class="capture-form" onsubmit="return false;">
        <input type="email" placeholder="Your email address" aria-label="Email address">
        <button type="submit" class="btn btn-black btn-dot">Join Free</button>
      </form>
    </div>
  </section>

</div>

<script>
(function(){
  var rm=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if(rm||!('IntersectionObserver' in window))return;
  document.body.classList.add('js-anim');
  var obs=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){e.target.classList.add('in-view');obs.unobserve(e.target);}
    });
  },{threshold:.12,rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.cortv2 .reveal').forEach(function(el){obs.observe(el);});
})();
</script>

