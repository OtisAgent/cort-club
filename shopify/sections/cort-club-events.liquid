        <h2 class="cc-events__heading">Events Coming Soon</h2>
      </div>
      <a href="#join" class="cc-btn-primary">Get Notified</a>
    </div>
    <div class="cc-events__grid">
      <div class="cc-event-card">
        <span class="cc-event-card__badge cc-event-card__badge--upcoming">Launching Soon</span>
        <h3 class="cc-event-card__title">Sheffield Americano</h3>
        <p class="cc-event-card__detail">◆ Sheffield</p>
        <p class="cc-event-card__detail">Mixed doubles · All levels welcome</p>
        <p class="cc-event-card__detail" style="margin-top:8px;font-size:13px;color:rgba(0,0,0,0.4);">Rotating format — everyone plays with everyone</p>
        <a href="#join" class="cc-event-card__cta">Register Interest →</a>
      </div>
      <div class="cc-event-card">
        <span class="cc-event-card__badge cc-event-card__badge--open">Open Format</span>
        <h3 class="cc-event-card__title"><span style="text-transform:none">cørt</span> Club League Night</h3>
        <p class="cc-event-card__detail">◆ TBC</p>
        <p class="cc-event-card__detail">Weekly · Rating-matched</p>
        <p class="cc-event-card__detail" style="margin-top:8px;font-size:13px;color:rgba(0,0,0,0.4);">Consistent competitive play every week</p>
        <a href="#join" class="cc-event-card__cta">Register Interest →</a>
      </div>
      <div class="cc-event-card">
        <span class="cc-event-card__badge cc-event-card__badge--tbd">Coming Q3 2026</span>
        <h3 class="cc-event-card__title"><span style="text-transform:none">cørt</span> Sponsor Open</h3>
        <p class="cc-event-card__detail">◆ TBC</p>
        <p class="cc-event-card__detail">Sponsored · Prize pool</p>
        <p class="cc-event-card__detail" style="margin-top:8px;font-size:13px;color:rgba(0,0,0,0.4);">Our first branded, broadcast-ready tournament</p>
        <a href="#join" class="cc-event-card__cta">Register Interest →</a>
      </div>
    </div>
  </div>
</section>

