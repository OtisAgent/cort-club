{{ 'cortv2.css' | asset_url | stylesheet_tag }}
{{ 'cort-partners.css' | asset_url | stylesheet_tag }}

<div class="cortv2 cp2">

  <section style="padding:100px 24px 90px">
    <div class="si" style="text-align:center">
      <p class="eyebrow reveal">CØRT Partners</p>
      <h1 class="reveal" style="--d:.06s">Your brand,<br>on court.</h1>
      <p class="reveal" style="--d:.12s;font-size:17px;color:var(--text);max-width:560px;margin:0 auto;line-height:1.7">List your full catalogue, clear end-of-line stock through CØRT Outlet, or join the repair network. One community. Three ways in.</p>
      <div class="reveal" style="--d:.18s;display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:36px">
        <a href="#apply" class="btn btn-y">List your catalogue</a>
        <a href="/pages/cort-outlet" class="btn btn-w">CØRT Outlet</a>
        <a href="#apply-repair" class="btn btn-w">Repair network</a>
      </div>
    </div>
  </section>

  <section style="background:#0a0a0a">
    <div class="si">
      <p class="eyebrow reveal">What you get</p>
      <h2 class="reveal" style="--d:.06s">Everything CØRT<br>puts behind you.</h2>
      <div class="pf-layout">
        <div class="pf-list reveal" style="--d:.1s">
          <div class="pf-item pf-on" data-pf="0"><span class="pf-num">01</span><span class="pf-title">CØRT Storefront</span><span class="pf-arr">&#8594;</span></div>
          <div class="pf-item" data-pf="1"><span class="pf-num">02</span><span class="pf-title">CØRT Outlet</span><span class="pf-arr">&#8594;</span></div>
          <div class="pf-item" data-pf="2"><span class="pf-num">03</span><span class="pf-title">CØRT TV Exposure</span><span class="pf-arr">&#8594;</span></div>
          <div class="pf-item" data-pf="3"><span class="pf-num">04</span><span class="pf-title">League &amp; Event Reach</span><span class="pf-arr">&#8594;</span></div>
          <div class="pf-item" data-pf="4"><span class="pf-num">05</span><span class="pf-title">KNECT Logistics</span><span class="pf-arr">&#8594;</span></div>
        </div>
        <div class="pf-panels reveal" style="--d:.14s">
          <div class="pf-panel pf-on" data-pf="0">
            <div class="pf-ico">&#9672;</div>
            <div class="pf-ptitle">CØRT Storefront</div>
            <p class="pf-pdesc">Your full catalogue listed on the CØRT store — where padel players already shop. We handle checkout, payments and marketing. You hold your own stock and dispatch direct to customers. No upfront cost, no warehousing handover needed. Partner login to manage your products and track sales.</p>
            <span class="pf-ptag">&#9670; Live now</span>
          </div>
          <div class="pf-panel" data-pf="1">
            <div class="pf-ico">&#11042;</div>
            <div class="pf-ptitle">CØRT Outlet — Sunday Clearance</div>
            <p class="pf-pdesc">Got end-of-line or excess stock? CØRT Outlet runs weekly Sunday drops — your surplus clears fast through an engaged audience without ever appearing on your own main storefront. Your brand stays premium; the stock moves. Outlet subscribers get first access — you send your nominated stock in to CØRT and we store, pack and ship every order.</p>
            <span class="pf-ptag">&#9670; Sundays</span>
          </div>
          <div class="pf-panel" data-pf="2">
            <div class="pf-ico">&#9673;</div>
            <div class="pf-ptitle">CØRT TV Exposure</div>
            <p class="pf-pdesc">Your brand in front of the padel community through live broadcast nights, league content and social reels. Scoreboard placements, lower-third graphics, sponsor credits — across every piece of CØRT TV content we produce.</p>
            <span class="pf-ptag">&#9670; Broadcast-ready</span>
          </div>
          <div class="pf-panel" data-pf="3">
            <div class="pf-ico">&#9670;</div>
            <div class="pf-ptitle">League &amp; Event Reach</div>
            <p class="pf-pdesc">Every CØRT league night, Americano and tournament is a marketing moment for your brand. Partners get exposure across event promotion, on-court presence, player communications and post-event recap content published across the community.</p>
            <span class="pf-ptag">&#9670; Community-wide</span>
          </div>
          <div class="pf-panel" data-pf="4">
            <div class="pf-ico">&#9654;</div>
            <div class="pf-ptitle">KNECT Logistics</div>
            <p class="pf-pdesc">Need fulfilment support? The HAF KNECT courier network gives partners optional access to logistics infrastructure for stock movement and last-mile delivery. No warehouse or carrier contracts required.</p>
            <span class="pf-ptag">&#9670; Coming soon</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="si">
      <p class="eyebrow reveal">Three ways in</p>
      <h2 class="reveal" style="--d:.06s">Pick your track.</h2>
      <div class="tracks-grid">
        <div class="track-card reveal">
          <div class="track-num">Track 01 — Brands</div>
          <div class="track-title">List your full catalogue</div>
          <p class="track-sub">Your whole range, live on the CØRT store. You keep and ship your own stock — we list it, market it and sell it to the padel community. One flat 20% founding commission on each sale. Partner login to manage products and track sales.</p>
          <ul class="tl"><li>Your full catalogue listed on the CØRT store</li><li>Marketed across CØRT TV, leagues and socials</li><li>You hold stock and dispatch direct to the customer</li><li>Partner login to manage products and track sales</li><li>CØRT handles storefront, checkout and marketing</li></ul>
          <a href="#apply" class="btn btn-y">Apply as a brand</a>
        </div>
        <div class="track-card reveal" style="--d:.05s">
          <div class="track-num">Track 02 — CØRT Outlet</div>
          <div class="track-title">Sunday clearance drops</div>
          <p class="track-sub">Got end-of-line or excess stock? CØRT Outlet runs weekly Sunday drops — cleared fast through an engaged audience without appearing on your own storefront. Your brand stays premium; the stock moves.</p>
          <ul class="tl"><li>End-of-line and excess stock cleared weekly</li><li>Sunday drops — built-in urgency and demand</li><li>Your brand never cheapened on your own channels</li><li>Send stock in — CØRT stores and ships every order</li><li>Same 20% founding commission — no extra fees</li></ul>
          <a href="/pages/cort-outlet" class="btn btn-y">Learn about CØRT Outlet</a>
        </div>
        <div class="track-card reveal" style="--d:.1s">
          <div class="track-num">Track 03 — Services</div>
          <div class="track-title">Repair network</div>
          <p class="track-sub">Repair, regrip or restore padel rackets? Get listed where players already are. The CØRT community books your services directly — you do the work, we bring the players.</p>
          <ul class="tl"><li>Listed in the CØRT repair network</li><li>Take bookings from the padel community</li><li>Crack repair, regrip and restoration services</li><li>Send-in repairs routed through CØRT</li><li>Local players routed to your bench</li></ul>
          <a href="#apply-repair" class="btn btn-y">Apply as a repairer</a>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="wanted-inner">
      <div class="wanted-label reveal">Wanted</div>
      <div class="wanted-title reveal" style="--d:.06s">We're looking for a racket repair business.</div>
      <p class="wanted-desc reveal" style="--d:.1s">Cracked bat? Broken frame? Padel players shouldn't have to bin a racket they love. We want one great repair business on the team: broken rackets get sent in through CØRT, you work your magic, and players get back on court for a fraction of the price of a new bat. You do the craft — we bring the customers, handle the storefront and take a commission on each job.</p>
      <a href="#apply-repair" class="btn btn-y reveal" style="--d:.14s">Apply to be our repair partner</a>
    </div>
  </section>

  <section>
    <div class="si">
      <p class="eyebrow reveal">How it works</p>
      <h2 class="reveal" style="--d:.06s">Three steps. That's it.</h2>
      <div class="steps-grid">
        <div class="step reveal"><div class="step-num">01</div><div class="step-title">Apply</div><p class="step-desc">Fill in the short form below — takes two minutes. Tell us who you are, what you sell, and whether you're interested in Outlet too.</p></div>
        <div class="step reveal" style="--d:.06s"><div class="step-num">02</div><div class="step-title">We review</div><p class="step-desc">Every partner is vetted. We check fit, quality and service so the community only sees the good stuff. You'll hear within 48 hours.</p></div>
        <div class="step reveal" style="--d:.12s"><div class="step-num">03</div><div class="step-title">You go live</div><p class="step-desc">Your full catalogue goes live on CØRT — you get a partner login to manage your products, track sales and nominate outlet stock.</p></div>
      </div>
    </div>
  </section>

  <section class="rate-sec">
    <div class="si">
      <div class="rate-num reveal">20%</div>
      <div class="rate-label reveal" style="--d:.06s">Flat founding rate — every partner</div>
      <p class="rate-desc reveal" style="--d:.1s">One flat rate. 20% on every sale. No listing fees, no hidden extras, no tiers. You keep 80% — we grow the game together. The same rate covers your full catalogue and any outlet stock.</p>
      <ul class="rb reveal" style="--d:.14s"><li>CØRT handles the storefront, checkout and marketing.</li><li>You handle stock and dispatch — your products, your shipping.</li><li>Need logistics? Fulfilment support through the HAF KNECT courier network is on the way.</li></ul>
    </div>
  </section>

  <section class="sponsor-sec">
    <div class="sponsor-inner">
      <p class="eyebrow reveal" style="color:rgba(0,0,0,.5)">CØRT TV</p>
      <div class="sponsor-title reveal" style="--d:.06s">Want to sponsor CØRT TV?</div>
      <p class="sponsor-desc reveal" style="--d:.1s">Reach the padel community through live broadcasts, league content and social reels. Download the full sponsorship pack to see every placement and package on offer.</p>
      <div class="sponsor-btns reveal" style="--d:.14s">
        <a href="/pages/sponsorship-pack" class="btn btn-blk">Download Sponsorship Pack</a>
        <a href="mailto:admin@cortclub.co.uk" class="btn-outline">Get in Touch &#8594;</a>
      </div>
    </div>
  </section>

  <section id="apply">
    <div class="si">
      <p class="eyebrow reveal">Apply now</p>
      <h2 class="reveal" style="--d:.06s">Get on court.</h2>
      <div class="forms-grid">
        <div class="form-card reveal">
          <h3>Track 01 — Brands</h3>
          <p class="form-sub">List your full catalogue on CØRT<br>Every partner is vetted. We'll come back to you within 48 hours.</p>
          <form class="cp2-form" data-success="brand-ok" action="https://formsubmit.co/ajax/admin@cortclub.co.uk" method="POST">
            <input type="hidden" name="_subject" value="New Brand Partner Application — CØRT">
            <input type="hidden" name="_captcha" value="false">
            <input type="text" name="_honey" style="display:none" tabindex="-1">
            <div class="field"><label>Brand name</label><input type="text" name="brand_name" required></div>
            <div class="field"><label>Registered company name &amp; number</label><input type="text" name="company_details" placeholder="e.g. ACME SPORTS LTD · 12345678" required></div>
            <div class="field"><label>VAT registered?</label><select name="vat_registered"><option value="" disabled selected>Select one</option><option value="yes">Yes</option><option value="no">No</option></select></div>
            <div class="field"><label>Contact name</label><input type="text" name="contact_name" required></div>
            <div class="field"><label>Your role</label><input type="text" name="contact_role" placeholder="Founder, sales director…"></div>
            <div class="field"><label>Email</label><input type="email" name="email" required></div>
            <div class="field"><label>Phone</label><input type="tel" name="phone" required></div>
            <div class="field"><label>Website</label><input type="text" name="website" required></div>
            <div class="field"><label>Instagram / socials</label><input type="text" name="socials"></div>
            <div class="field"><label>What do you sell?</label><div class="cb-row"><label><input type="checkbox" name="cat_rackets"> Rackets</label><label><input type="checkbox" name="cat_apparel"> Apparel</label><label><input type="checkbox" name="cat_accessories"> Accessories</label><label><input type="checkbox" name="cat_footwear"> Footwear</label><label><input type="checkbox" name="cat_balls"> Balls</label><label><input type="checkbox" name="cat_other"> Other</label></div></div>
            <div class="field"><label>Roughly how many products in your range?</label><select name="catalogue_size"><option value="" disabled selected>Select a range</option><option value="1-10">1–10 products</option><option value="11-50">11–50 products</option><option value="51-200">51–200 products</option><option value="200+">200+ products</option></select></div>
            <div class="field"><label>Typical retail price range</label><select name="price_range"><option value="" disabled selected>Select one</option><option value="under-25">Under £25</option><option value="25-75">£25–£75</option><option value="75-150">£75–£150</option><option value="150+">£150+</option><option value="mixed">Mixed across the range</option></select></div>
            <div class="field"><label>Where is stock held?</label><input type="text" name="stock_location" placeholder="City / country" required></div>
            <div class="field"><label>Dispatch time on orders</label><select name="dispatch_time"><option value="" disabled selected>Select one</option><option value="same-day">Same day</option><option value="1-2-days">1–2 working days</option><option value="3-5-days">3–5 working days</option><option value="longer">Longer</option></select></div>
            <div class="field"><label>Can you ship direct to customers?</label><select name="ships_direct"><option value="" disabled selected>Select one</option><option value="yes">Yes — we dispatch our own orders</option><option value="no">No — we'd need fulfilment support</option></select></div>
            <div class="field"><label>Interested in CØRT Outlet — Sunday clearance drops?</label><select name="outlet_interest"><option value="" disabled selected>Select one</option><option value="yes">Yes — I have end-of-line stock</option><option value="maybe">Maybe later</option><option value="no">Not right now</option></select></div>
            <div class="field"><label>Roughly how much end-of-line stock per season?</label><select name="outlet_volume"><option value="" disabled selected>Select one</option><option value="none">None yet</option><option value="under-50">Under 50 units</option><option value="50-250">50–250 units</option><option value="250+">250+ units</option></select></div>
            <div class="field"><label>Interested in CØRT TV auctions or prize placements?</label><select name="tv_interest"><option value="" disabled selected>Select one</option><option value="auctions">Live auctions</option><option value="prizes">Prizes</option><option value="both">Both</option><option value="no">Not right now</option></select></div>
            <div class="field"><label>Anything else? (optional)</label><textarea name="notes" placeholder="Seasonal ranges, exclusives, special pricing…"></textarea></div>
            <div class="field"><div class="cb-row"><label><input type="checkbox" name="confirm_authorised" required> I'm authorised to act for this brand and the details above are accurate.</label></div></div>
            <button type="submit" class="btn btn-y">Submit application</button>
          </form>
          <div class="form-ok" id="brand-ok"><div class="tick">&#9673;</div><p>Application received — we'll review within 48 hours. If you're a fit, you'll receive our partner terms to sign electronically, then your partner login to upload your catalogue and go live on the CØRT store.</p></div>
        </div>
        <div class="form-card reveal" style="--d:.08s" id="apply-repair">
          <h3>Track 03 — Services</h3>
          <p class="form-sub">Join the repair network<br>Every partner is vetted. We'll come back to you within 48 hours.</p>
          <form class="cp2-form" data-success="repair-ok" action="https://formsubmit.co/ajax/admin@cortclub.co.uk" method="POST">
            <input type="hidden" name="_subject" value="New Repair Partner Application — CØRT">
            <input type="hidden" name="_captcha" value="false">
            <input type="text" name="_honey" style="display:none" tabindex="-1">
            <div class="field"><label>Business name</label><input type="text" name="business_name" required></div>
            <div class="field"><label>Contact name</label><input type="text" name="contact_name" required></div>
            <div class="field"><label>Email</label><input type="email" name="email" required></div>
            <div class="field"><label>Phone</label><input type="tel" name="phone"></div>
            <div class="field"><label>Location / city</label><input type="text" name="location" required></div>
            <div class="field"><label>Services offered</label><div class="cb-row"><label><input type="checkbox" name="service_crack"> Crack repair</label><label><input type="checkbox" name="service_regrip"> Regrip</label><label><input type="checkbox" name="service_restore"> Restore</label></div></div>
            <div class="field"><label>Typical turnaround</label><input type="text" name="turnaround"></div>
            <button type="submit" class="btn btn-y">Submit application</button>
          </form>
          <div class="form-ok" id="repair-ok"><div class="tick">&#9673;</div><p>Application received. We'll come back to you within 48 hours.</p></div>
        </div>
      </div>
    </div>
  </section>

</div>

<script>
(function(){
  var rm=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if(!rm&&'IntersectionObserver' in window){
    document.body.classList.add('js-anim');
    var obs=new IntersectionObserver(function(entries){
      entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in-view');obs.unobserve(e.target);}});
    },{threshold:.1,rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('.cp2 .reveal').forEach(function(el){obs.observe(el);});
  }
  document.querySelectorAll('.cp2-form').forEach(function(form){
    form.addEventListener('submit',function(e){
      e.preventDefault();
      var btn=form.querySelector('[type=submit]');
      btn.textContent='Sending…';btn.disabled=true;
      fetch(form.action,{method:'POST',body:new FormData(form),headers:{'Accept':'application/json'}})
        .then(function(r){return r.json();})
        .then(function(){form.style.display='none';var s=document.getElementById(form.getAttribute('data-success'));if(s)s.style.display='block';})
        .catch(function(){btn.textContent='Submit application';btn.disabled=false;});
    });
  });
  var pfItems=document.querySelectorAll('.cp2 .pf-item');
  var pfPanels=document.querySelectorAll('.cp2 .pf-panel');
  function apf(idx){pfItems.forEach(function(i){i.classList.remove('pf-on');});pfPanels.forEach(function(p){p.classList.remove('pf-on');});var it=document.querySelector('.cp2 .pf-item[data-pf="'+idx+'"]');var pn=document.querySelector('.cp2 .pf-panel[data-pf="'+idx+'"]');if(it)it.classList.add('pf-on');if(pn)pn.classList.add('pf-on');}
  pfItems.forEach(function(item){item.addEventListener('mouseenter',function(){apf(item.getAttribute('data-pf'));});item.addEventListener('click',function(e){e.preventDefault();apf(item.getAttribute('data-pf'));});});
})();
</script>

