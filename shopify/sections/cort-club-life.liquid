{% comment %} cørt Club — Club Life: animated symbols + diagrams (no photography) + rating explainer + Quick Play promo {% endcomment %}
<section class="cc-life">
  <div class="cc-life-in">

    <div class="cc-life-head">
      <div class="cc-eyebrow">Club Life</div>
      <h2>This is what we're building.</h2>
    </div>

    <div class="cc-banner">
      <svg class="cc-court" viewBox="0 0 940 400" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice" aria-label="Padel court diagram with a rally in motion">
        <rect class="cc-line" x="70" y="40" width="800" height="320"/>
        <line class="cc-line cc-net" x1="470" y1="40" x2="470" y2="360"/>
        <line class="cc-line" x1="170" y1="200" x2="770" y2="200" style="animation-delay:.5s"/>
        <line class="cc-line" x1="170" y1="40" x2="170" y2="360" style="animation-delay:.7s"/>
        <line class="cc-line" x1="770" y1="40" x2="770" y2="360" style="animation-delay:.7s"/>
        <circle class="cc-p" cx="260" cy="120" r="11"/>
        <circle class="cc-p" cx="260" cy="280" r="11" style="animation-delay:.4s"/>
        <circle class="cc-p cc-p2" cx="680" cy="120" r="11" style="animation-delay:.2s"/>
        <circle class="cc-p cc-p2" cx="680" cy="280" r="11" style="animation-delay:.6s"/>
        <circle class="cc-ball" cx="0" cy="0" r="7"/>
      </svg>
      <div class="cc-banner-cap">Every point counts<span class="cc-dot">.</span></div>
    </div>

    <div class="cc-cards">
      <div class="cc-card">
        <div class="cc-card-sym">
          <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="60" cy="60" r="38" fill="none" stroke="rgba(255,234,0,.25)" stroke-width="2" stroke-dasharray="6 8"/>
            <g class="cc-orbit">
              <circle cx="60" cy="22" r="8" fill="#FFEA00"/>
              <circle cx="98" cy="60" r="8" fill="#fff"/>
              <circle cx="60" cy="98" r="8" fill="#FFEA00"/>
              <circle cx="22" cy="60" r="8" fill="#fff"/>
            </g>
            <circle cx="60" cy="60" r="4" fill="#FFEA00"/>
          </svg>
        </div>
        <div class="cc-card-body">
          <h3>Club nights</h3>
          <p>Structured socials on real courts. Turn up on your own, get drawn into the rotation, leave with a crew.</p>
        </div>
      </div>
      <div class="cc-card">
        <div class="cc-card-sym">
          <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <g fill="rgba(255,255,255,.22)">
              <circle cx="24" cy="30" r="3"/><circle cx="52" cy="24" r="3"/><circle cx="82" cy="32" r="3"/>
              <circle cx="30" cy="62" r="3"/><circle cx="96" cy="58" r="3"/><circle cx="22" cy="92" r="3"/>
              <circle cx="56" cy="98" r="3"/><circle cx="90" cy="90" r="3"/>
            </g>
            <circle class="cc-ping" cx="62" cy="56" r="10" fill="none" stroke="#FFEA00" stroke-width="2"/>
            <circle class="cc-ping cc-ping2" cx="62" cy="56" r="10" fill="none" stroke="#FFEA00" stroke-width="2"/>
            <path d="M62 34c-12 0-21 9-21 21 0 15 21 33 21 33s21-18 21-33c0-12-9-21-21-21z" fill="#FFEA00"/>
            <circle cx="62" cy="55" r="8" fill="#000"/>
          </svg>
        </div>
        <div class="cc-card-body">
          <h3>Real venues</h3>
          <p>We run events at partner clubs across the UK — starting in Sheffield, growing city by city.</p>
        </div>
      </div>
      <div class="cc-card">
        <div class="cc-card-sym">
          <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <line class="cc-link" x1="38" y1="42" x2="82" y2="42" stroke="rgba(255,234,0,.55)" stroke-width="2"/>
            <line class="cc-link" x1="38" y1="82" x2="82" y2="82" stroke="rgba(255,234,0,.55)" stroke-width="2" style="animation-delay:.5s"/>
            <line x1="60" y1="24" x2="60" y2="100" stroke="rgba(255,255,255,.18)" stroke-width="2" stroke-dasharray="4 6"/>
            <circle class="cc-pair" cx="34" cy="42" r="9" fill="#fff"/>
            <circle class="cc-pair" cx="86" cy="42" r="9" fill="#FFEA00" style="animation-delay:.25s"/>
            <circle class="cc-pair" cx="34" cy="82" r="9" fill="#FFEA00" style="animation-delay:.5s"/>
            <circle class="cc-pair" cx="86" cy="82" r="9" fill="#fff" style="animation-delay:.75s"/>
          </svg>
        </div>
        <div class="cc-card-body">
          <h3>Your people</h3>
          <p>Padel is a doubles game — nobody plays it alone. Find partners, subs and rivals at your level.</p>
        </div>
      </div>
    </div>

    <div class="cc-rating">
      <div class="cc-eyebrow">The <span class="cbr">cørt</span> Rating, explained</div>
      <div class="cc-rating-grid">
        <div class="cc-rstep">
          <div class="cc-rtop"><div class="cc-rnum">01</div>
            <svg class="cc-rsym" viewBox="0 0 64 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <line x1="4" y1="36" x2="60" y2="36" stroke="rgba(255,255,255,.25)" stroke-width="2"/>
              <circle class="cc-bounce" cx="14" cy="14" r="6" fill="#FFEA00"/>
            </svg>
          </div>
          <h4>Play</h4><p>Every match at a cørt event is logged — league nights, Americanos, tournaments, all of it.</p>
        </div>
        <div class="cc-rstep">
          <div class="cc-rtop"><div class="cc-rnum">02</div>
            <svg class="cc-rsym" viewBox="0 0 64 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path class="cc-arrow" d="M6 32 L30 18 L42 26 L58 8" fill="none" stroke="#FFEA00" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M46 8 L58 8 L58 20" fill="none" stroke="#FFEA00" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h4>Earn</h4><p>Points are weighted by who you beat. Taking a game off stronger pairs moves you more than easy wins.</p>
        </div>
        <div class="cc-rstep">
          <div class="cc-rtop"><div class="cc-rnum">03</div>
            <svg class="cc-rsym" viewBox="0 0 64 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect class="cc-bar" x="8" y="24" width="10" height="12" fill="rgba(255,255,255,.35)"/>
              <rect class="cc-bar" x="26" y="16" width="10" height="20" fill="rgba(255,234,0,.6)" style="animation-delay:.2s"/>
              <rect class="cc-bar" x="44" y="6" width="10" height="30" fill="#FFEA00" style="animation-delay:.4s"/>
            </svg>
          </div>
          <h4>Rise</h4><p>Your rating follows you to every venue — so you always land in games that stretch you, not bore you.</p>
        </div>
      </div>
    </div>

    <div class="cc-qp">
      <div class="cc-qp-txt">
        <h3>Running a session tonight?</h3>
        <p>cørt Play's Quick Play runs your Americano, Mexicano or King of the Court for free — type names, tap scores, live leaderboard. No accounts needed.</p>
      </div>
      <a class="cc-qp-btn" href="https://play.cortclub.co.uk/quick">Open Quick Play</a>
    </div>

  </div>
</section>

<style>
.cc-life { background:#000; color:#fff; padding:72px 20px; }
.cc-life-in { max-width:1080px; margin:0 auto; }
.cc-life .cc-eyebrow { font-size:11px; font-weight:800; letter-spacing:0.18em; text-transform:uppercase; color:#FFEA00; margin-bottom:14px; }
.cc-life-head h2 { font-size:clamp(1.7rem,4vw,2.6rem); font-weight:900; letter-spacing:-0.03em; margin:0 0 34px; }
.cc-dot { color:#FFEA00; }

.cc-banner { position:relative; border:1px solid rgba(255,255,255,0.12); margin-bottom:14px; background:#0d0d0d; }
.cc-court { display:block; width:100%; aspect-ratio:2.35/1; }
.cc-line { fill:none; stroke:rgba(255,234,0,.55); stroke-width:2.5; stroke-dasharray:2400; stroke-dashoffset:2400; animation:ccDraw 1.6s ease forwards .2s; }
.cc-net { stroke:rgba(255,255,255,.5); stroke-dasharray:8 8; animation:none; stroke-dashoffset:0; }
@keyframes ccDraw { to { stroke-dashoffset:0; } }
.cc-p { fill:#fff; opacity:.85; animation:ccStep 3.2s ease-in-out infinite; }
.cc-p2 { fill:#FFEA00; }
@keyframes ccStep { 0%,100% { transform:translate(0,0); } 50% { transform:translate(0,-10px); } }
.cc-ball { fill:#FFEA00; offset-path:path('M260 130 Q 470 40 660 250 Q 470 340 280 260 Q 470 120 680 130'); animation:ccRally 6s linear infinite .8s; }
@keyframes ccRally { 0% { offset-distance:0%; } 100% { offset-distance:100%; } }
.cc-banner-cap { position:absolute; left:18px; bottom:14px; background:#000; color:#fff; font-weight:900; font-size:clamp(0.95rem,2.2vw,1.25rem); letter-spacing:-0.02em; padding:8px 14px; border:1px solid rgba(255,234,0,.35); }

.cc-cards { display:grid; grid-template-columns:repeat(auto-fit,minmax(250px,1fr)); gap:14px; margin-bottom:56px; margin-top:14px; }
.cc-card { background:#0d0d0d; border:1px solid rgba(255,255,255,0.12); box-shadow:6px 6px 0 #FFEA00; }
.cc-card-sym { display:flex; align-items:center; justify-content:center; aspect-ratio:4/3; border-bottom:1px solid rgba(255,255,255,.08); }
.cc-card-sym svg { width:56%; max-width:170px; height:auto; }
.cc-orbit { transform-origin:60px 60px; animation:ccOrbit 14s linear infinite; }
@keyframes ccOrbit { to { transform:rotate(360deg); } }
.cc-ping { transform-origin:62px 56px; animation:ccPing 2.6s ease-out infinite; opacity:0; }
.cc-ping2 { animation-delay:1.3s; }
@keyframes ccPing { 0% { transform:scale(.6); opacity:.9; } 80% { transform:scale(3.4); opacity:0; } 100% { opacity:0; } }
.cc-pair { animation:ccPulse 2.4s ease-in-out infinite; }
@keyframes ccPulse { 0%,100% { opacity:.65; } 50% { opacity:1; } }
.cc-link { stroke-dasharray:60; stroke-dashoffset:60; animation:ccLink 2.4s ease infinite; }
@keyframes ccLink { 40%,70% { stroke-dashoffset:0; } 100% { stroke-dashoffset:-60; } }
.cc-card-body { padding:18px; }
.cc-card-body h3 { font-size:1.05rem; font-weight:900; margin:0 0 8px; letter-spacing:-0.02em; }
.cc-card-body p { font-size:0.85rem; line-height:1.6; color:rgba(255,255,255,0.55); margin:0; }

.cc-rating { margin-bottom:56px; }
.cc-rating-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:14px; }
.cc-rstep { border:1px solid rgba(255,255,255,0.12); padding:22px 18px; background:#0d0d0d; }
.cc-rtop { display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; }
.cc-rnum { font-size:12px; font-weight:900; color:#FFEA00; letter-spacing:0.14em; }
.cc-rsym { width:64px; height:40px; }
.cc-bounce { animation:ccBounce 1.6s cubic-bezier(.5,0,.5,1) infinite alternate; }
@keyframes ccBounce { 0% { transform:translate(0,0); } 100% { transform:translate(34px,16px); } }
.cc-arrow { stroke-dasharray:90; stroke-dashoffset:90; animation:ccEarn 2.8s ease infinite; }
@keyframes ccEarn { 45%,80% { stroke-dashoffset:0; } 100% { stroke-dashoffset:0; } }
.cc-bar { transform-origin:bottom; animation:ccRise 2.6s ease infinite; }
@keyframes ccRise { 0% { transform:scaleY(.2); } 45%,100% { transform:scaleY(1); } }
.cc-rstep h4 { font-size:1rem; font-weight:900; margin:0 0 8px; }
.cc-rstep p { font-size:0.85rem; line-height:1.6; color:rgba(255,255,255,0.55); margin:0; }

.cc-qp { display:flex; align-items:center; justify-content:space-between; gap:20px; flex-wrap:wrap; border:2px solid #FFEA00; background:#0d0d0d; padding:26px 24px; box-shadow:8px 8px 0 rgba(255,234,0,0.25); }
.cc-qp-txt h3 { font-size:1.2rem; font-weight:900; margin:0 0 8px; letter-spacing:-0.02em; }
.cc-qp-txt p { font-size:0.88rem; line-height:1.6; color:rgba(255,255,255,0.6); margin:0; max-width:620px; }
.cc-qp-btn { flex:0 0 auto; background:#FFEA00; color:#000; font-weight:900; font-size:0.9rem; padding:15px 26px; text-decoration:none; letter-spacing:0.02em; }
.cc-qp-btn:hover { transform:translate(-2px,-2px); box-shadow:4px 4px 0 rgba(255,234,0,0.4); }

@media (max-width:640px){
  .cc-life { padding:52px 16px; }
  .cc-qp { flex-direction:column; align-items:stretch; text-align:center; }
}
@supports not (offset-path: path('M0 0')) { .cc-ball { display:none; } }
@media (prefers-reduced-motion:reduce){
  .cc-line { animation:none; stroke-dashoffset:0; }
  .cc-ball, .cc-p, .cc-orbit, .cc-ping, .cc-ping2, .cc-pair, .cc-link, .cc-bounce, .cc-arrow, .cc-bar { animation:none; }
  .cc-ball { offset-distance:30%; }
}
</style>

