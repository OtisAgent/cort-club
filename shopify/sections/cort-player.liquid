{{ 'cort-player.css' | asset_url | stylesheet_tag }}

<div class="cort-player">
  <div class="cpl-wrap">

    <div class="cpl-hero">
      <span class="cpl-soon-pill">cøming søøn</span>
      <p class="cpl-eyebrow">cørt player</p>
      <h1>Where your padel<br>story gets <em>built.</em></h1>
      <p class="cpl-sub">Most padel apps just book you a court. <b>cørt gives you a competitive identity</b> — a player number, a level, a ranking, titles and a journey from your first club night all the way to a national championship. Play, climb, and be seen.</p>
    </div>

    <div class="cpl-sec">
      <div class="cpl-sec-head">
        <p class="cpl-eyebrow">your identity</p>
        <h2>The cørt Player Passport</h2>
        <p class="cpl-lead">One account that follows you everywhere — every social night, open, league and championship builds the same permanent record.</p>
      </div>
      <div class="cpl-passport-wrap">
        <div class="cpl-passport">
          <div class="cpl-pp-top">
            <div class="cpl-pp-brand">cørt<span class="cpl-dot">.</span></div>
            <div class="cpl-pp-tier">cørt ranked</div>
          </div>
          <div class="cpl-pp-name">Sample Player</div>
          <div class="cpl-pp-sub">Sheffield &middot; Home venue: Padel Yard</div>
          <div class="cpl-pp-num">#128</div>
          <div class="cpl-pp-stats">
            <div class="cpl-pp-stat"><b>34</b><span>Played</span></div>
            <div class="cpl-pp-stat"><b>21</b><span>Wins</span></div>
            <div class="cpl-pp-stat"><b>#7</b><span>City rank</span></div>
          </div>
          <div class="cpl-pp-badges">
            <span class="cpl-pp-badge">Founding Player</span>
            <span class="cpl-pp-badge">League Finalist</span>
            <span class="cpl-pp-badge">Best Comeback</span>
          </div>
        </div>
        <div class="cpl-passport-note">
          <h3>What's on your card</h3>
          <ul>
            <li><b>Player number &amp; level</b> — your identity from day one</li>
            <li><b>Live ranking</b> — city, regional and national</li>
            <li><b>Record</b> — matches, wins, titles, finals reached</li>
            <li><b>Badges &amp; records</b> — earned, not bought</li>
            <li><b>Clips &amp; awards</b> — your best moments, kept</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="cpl-sec">
      <div class="cpl-sec-head">
        <p class="cpl-eyebrow">how it works</p>
        <h2>Four steps in</h2>
      </div>
      <div class="cpl-steps">
        <div class="cpl-step"><span class="cpl-n">1</span><b>Create your account</b><span>Name, city, home venue — your player passport starts here</span></div>
        <div class="cpl-step"><span class="cpl-n">2</span><b>Set your level</b><span>A quick assessment night places you fairly</span></div>
        <div class="cpl-step"><span class="cpl-n">3</span><b>Play &amp; climb</b><span>Club nights, opens and leagues earn you ranking points</span></div>
        <div class="cpl-step"><span class="cpl-n">4</span><b>Earn your status</b><span>Titles, badges and a route to regional &amp; national</span></div>
      </div>
    </div>

    <div class="cpl-sec">
      <div class="cpl-sec-head">
        <p class="cpl-eyebrow">membership</p>
        <h2>Pick how you play</h2>
        <p class="cpl-lead">Start free, upgrade when you're hooked. Every tier feeds the same passport — you never lose your history.</p>
      </div>
      <div class="cpl-tiers">
        <div class="cpl-tier">
          <div class="cpl-tag">Start here</div>
          <h3>cørt free</h3>
          <ul>
            <li>Player account &amp; passport</li>
            <li>Find &amp; join events near you</li>
            <li>Basic results &amp; profile</li>
            <li>Follow the leagues &amp; rankings</li>
          </ul>
          <span class="cpl-soon-tag">søøn</span>
        </div>
        <div class="cpl-tier cpl-feat">
          <div class="cpl-tag">Most popular</div>
          <h3>cørt member</h3>
          <ul>
            <li><b>Cheaper</b> event entry</li>
            <li>Full player passport &amp; ranking eligibility</li>
            <li>Priority booking &amp; member-only nights</li>
            <li>Digital player card</li>
            <li>Merch offers on achievements</li>
          </ul>
          <span class="cpl-soon-tag">søøn</span>
        </div>
        <div class="cpl-tier">
          <div class="cpl-tag">For the serious</div>
          <h3>cørt pro</h3>
          <ul>
            <li>Everything in member</li>
            <li><b>Full stats</b> &amp; performance reviews</li>
            <li>Video profile &amp; featured clips</li>
            <li>Priority league placement</li>
            <li>Premium event &amp; partner access</li>
          </ul>
          <span class="cpl-soon-tag">søøn</span>
        </div>
      </div>
      <p class="cpl-tiers-note">Pricing lands at launch — memberships open with the first city.</p>
    </div>

    <div class="cpl-sec">
      <div class="cpl-sec-head">
        <p class="cpl-eyebrow">status</p>
        <h2>Climb the ranks</h2>
        <p class="cpl-lead">Every player starts as Registered. Where you finish is up to you — and it's all earned through transparent, published criteria.</p>
      </div>
      <div class="cpl-ladder">
        <div class="cpl-rung"><span class="cpl-r">1</span>Registered</div>
        <div class="cpl-rung"><span class="cpl-r">2</span>Competitor</div>
        <div class="cpl-rung"><span class="cpl-r">3</span>Ranked</div>
        <div class="cpl-rung"><span class="cpl-r">4</span>Contender</div>
        <div class="cpl-rung"><span class="cpl-r">5</span>Regional</div>
        <div class="cpl-rung"><span class="cpl-r">6</span>National</div>
        <div class="cpl-rung cpl-top"><span class="cpl-r">7</span>Champion</div>
      </div>
    </div>

    <div class="cpl-sec">
      <div class="cpl-sec-head">
        <p class="cpl-eyebrow">the pathway</p>
        <h2>From first night to the nationals</h2>
        <p class="cpl-lead">One connected ladder. Win locally, qualify regionally, and earn your place at the national championship.</p>
      </div>
      <div class="cpl-journey">
        <div class="cpl-jstep">
          <span class="cpl-ico"><svg viewBox="0 0 24 24"><circle cx="9" cy="8" r="3"/><circle cx="17" cy="9" r="2.2"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6M15.5 14c2.8.2 5 2.5 5 5.5"/></svg></span>
          <b>Club Night</b><span>Turn up, play, meet the scene</span>
        </div>
        <div class="cpl-jstep">
          <span class="cpl-ico"><svg viewBox="0 0 24 24"><path d="M8 21h8M12 17v4M6 4h12v5a6 6 0 0 1-12 0z"/><path d="M6 6H3.5v1.5A2.5 2.5 0 0 0 6 10M18 6h2.5v1.5A2.5 2.5 0 0 1 18 10"/></svg></span>
          <b>Local Open</b><span>Your first titles &amp; ranking points</span>
        </div>
        <div class="cpl-jstep">
          <span class="cpl-ico"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18M9 9v11M15 9v11"/></svg></span>
          <b>City League</b><span>Weekly team, rivalries, a table</span>
        </div>
        <div class="cpl-jstep">
          <span class="cpl-ico"><svg viewBox="0 0 24 24"><path d="M12 2 3 7v6c0 5 3.8 8 9 9 5.2-1 9-4 9-9V7z"/><path d="M9 12l2 2 4-4"/></svg></span>
          <b>Regional Finals</b><span>Qualify, on a feature court</span>
        </div>
        <div class="cpl-jstep">
          <span class="cpl-ico"><svg viewBox="0 0 24 24"><path d="M6 9V4h12v5M6 4H4v3a3 3 0 0 0 3 3M18 4h2v3a3 3 0 0 1-3 3M9 20h6M12 15v5M8 12a4 4 0 0 0 8 0"/></svg></span>
          <b>National Champs</b><span>The season climax, live on cørt TV</span>
        </div>
      </div>
    </div>

    <div class="cpl-sec">
      <div class="cpl-soon">
        <div class="cpl-soon-big">cøming søøn<span class="cpl-dot">.</span></div>
        <p>The <b>cørt player passport</b> is being built right now. Club nights first, then the ladder — city by city, Sheffield first. Get your grip socks ready.</p>
        <span class="cpl-soon-wink">yes, that's how we spell soon.</span>
      </div>
      <div class="cpl-foot">
        cørt club &middot; where padel happens<br>
        Questions? <a href="/pages/contact">Talk to the team</a>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "cørt Player",
  "settings": []
}
{% endschema %}
